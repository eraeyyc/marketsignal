# MarketSignal — environment variables template
# Copy to .env and fill in real values. Never commit .env.

# OpenSky Network OAuth2
OPENSKY_CLIENT_ID=your_client_id
OPENSKY_CLIENT_SECRET=your_client_secret

# Cirium Sky API — NOTAMs (My Cirium portal → Credential Management)
# Use the Identifier as the token — goes directly in the Authorization header
CIRIUM_SKY_APP_ID=your-identifier-uuid-here
# Keep the Secret stored here for reference but it is not used in requests
CIRIUM_SKY_APP_KEY=your-secret-here

# Cirium Flex API (flight schedules + route status)
CIRIUM_FLEX_APP_ID=your_app_id_here
CIRIUM_FLEX_APP_KEY=your_app_key_here

# aisstream.io — AIS maritime data (free tier at aisstream.io)
AISSTREAM_API_KEY=your_api_key_here

# Polymarket — NO API KEY REQUIRED
# The Gamma API (https://gamma-api.polymarket.com) is fully public for read-only access.
# Run: python3 polymarket_collector.py --loop

# Google BigQuery — path to service account JSON file on this machine
GOOGLE_APPLICATION_CREDENTIALS=/home/marketsignal/gdelt_credentials.json
BIGQUERY_PROJECT_ID=marketsignal-489510
