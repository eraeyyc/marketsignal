# MarketSignal — environment variables template
# Copy to .env and fill in real values. Never commit .env.

# OpenSky Network OAuth2
OPENSKY_CLIENT_ID=your_client_id
OPENSKY_CLIENT_SECRET=your_client_secret

# Cirium Sky API (generate from My Cirium portal → Credential Management)
CIRIUM_API_TOKEN=your_48_char_token_here

# Google BigQuery — path to service account JSON file on this machine
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gdelt_credentials.json
BIGQUERY_PROJECT_ID=marketsignal-489510
